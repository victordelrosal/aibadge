rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helper: is the current user the admin (Victor)?
    // ----------------------------------------------------------------
    function isAdmin() {
      return request.auth != null
          && (request.auth.token.email == "victor@fiveinnolabs.com"
              || request.auth.token.email == "victordelrosal@gmail.com");
    }

    function isOwner(userId) {
      return request.auth != null
          && request.auth.uid == userId;
    }

    // ----------------------------------------------------------------
    // Users: owners can read/write their own doc; admin reads all
    // ----------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      // Assessments subcollection (baseline, final)
      match /assessments/{assessmentId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // Explorer history subcollection
      match /explorer_history/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // Weeks / Exercises subcollections
      match /weeks/{weekNum} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();

        match /exercises/{exerciseId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }

      // Login history subcollection
      match /logins/{loginId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if false;
      }

      // Tutorial completion subcollection
      match /tutorial_completions/{tutorialId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }

      // Exercise submissions subcollection (URL/text/file artefacts)
      match /submissions/{exerciseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();

        // Archive of prior submissions (kept for audit when user edits/deletes)
        match /archive/{archiveId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }

    // ----------------------------------------------------------------
    // Collection-group read for submissions (admin only).
    // Enables collectionGroup('submissions') queries across all users.
    // Per-user read/write is still governed by the nested rule above.
    // ----------------------------------------------------------------
    match /{path=**}/submissions/{exerciseId} {
      allow read: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Programmes: readable by any authenticated user
    // ----------------------------------------------------------------
    match /programmes/{programmeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Public assessments: anyone can create (lead capture);
    // only admin can read
    // ----------------------------------------------------------------
    match /public_assessments/{docId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ----------------------------------------------------------------
    // Viral Tree: referral code -> owner uid map.
    // Public read so a share link (?ref=CODE) resolves for visitors who
    // are not yet signed in. A user may only create the code that points
    // to their own uid. No money attached: the code just resolves a referrer.
    // ----------------------------------------------------------------
    match /referral_codes/{code} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Viral Tree: referral edges (who referred whom).
    // The REFERRED user creates the edge for themselves on signup
    // (referredId must equal their own uid, and they cannot refer
    // themselves), so no one can fabricate referrals for other accounts.
    // Both parties + admin can read. status flips signed_up -> paid
    // later, admin/server only.
    // ----------------------------------------------------------------
    match /referrals/{rid} {
      allow read: if request.auth != null
                  && (resource.data.referrerId == request.auth.uid
                      || resource.data.referredId == request.auth.uid
                      || isAdmin());
      allow create: if request.auth != null
                    && request.resource.data.referredId == request.auth.uid
                    && request.resource.data.referrerId != request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Collection-group read so admin analytics can sweep all referrals.
    match /{path=**}/referrals/{rid} {
      allow read: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Viral Tree: outstanding invites (who was emailed, not yet joined).
    // The INVITER creates/refreshes their own invite record (inviterId
    // must equal their own uid). Only the inviter + admin can read them.
    // No PII of third parties is exposed to anyone but the sender.
    // ----------------------------------------------------------------
    match /invites/{iid} {
      allow read: if request.auth != null
                  && (resource.data.inviterId == request.auth.uid || isAdmin());
      allow create, update: if request.auth != null
                  && request.resource.data.inviterId == request.auth.uid;
      allow delete: if isAdmin();
    }
    match /{path=**}/invites/{iid} {
      allow read: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Default deny
    // ----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
